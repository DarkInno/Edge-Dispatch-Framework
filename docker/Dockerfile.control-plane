FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /control-plane ./cmd/control-plane

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /control-plane /control-plane
EXPOSE 8080
ENTRYPOINT ["/control-plane"]

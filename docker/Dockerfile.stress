FROM golang:1.24-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /stress ./cmd/stress

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
RUN adduser -D -g '' appuser
COPY --from=builder /stress /usr/local/bin/stress
USER appuser
ENTRYPOINT ["stress"]

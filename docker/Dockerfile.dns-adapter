FROM golang:1.22-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /dns-adapter ./cmd/dns-adapter

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /dns-adapter /usr/local/bin/dns-adapter
EXPOSE 5353/udp
ENTRYPOINT ["dns-adapter"]
